<advancedsettings>
  <services>
    <!-- Master UPnP switch — must be ON for renderer/controller to work -->
    <upnp>true</upnp>
    <upnpserver>false</upnpserver>
    <upnprenderer>true</upnprenderer>
    <!-- Allow UPnP controllers to push media to this Kodi instance -->
    <upnpcontroller>true</upnpcontroller>
  </services>

  <!-- Lock Kodi into audio-only mode (no video library/gui). -->
  <video>
    <enable>false</enable>
  </video>

  <!-- Use the built-in audio player (PAPlayer) for all media. -->
  <audio>
    <defaultplayer>PAPlayer</defaultplayer>
  </audio>

  <!-- Disable screensaver (headless, no display to protect). -->
  <screensaver>
    <mode>default</mode>
    <time>0</time>
  </screensaver>

  <!-- Reduce logging noise in container. -->
  <loglevel>WARNING</loglevel>
</advancedsettings>
